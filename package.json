{
  "name": "hauki-admin-ui",
  "version": "1.14.1",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.1"
  },
  "dependencies": {
    "@axe-core/react": "^4.8.4",
    "@eslint/js": "^9.39.1",
    "@nabla/vite-plugin-eslint": "^3.0.1",
    "@sentry/react": "^10.24.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.2",
    "@types/testing-library__dom": "7.5.0",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "date-fns": "2.29.3",
    "date-holidays": "^3.16.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.39.1",
    "eslint-config-vitest-globals": "^2.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "esrun": "^3.2.26",
    "globals": "^17.4.0",
    "hds-core": "^5.0.0",
    "hds-design-tokens": "^5.0.0",
    "hds-react": "^5.0.0",
    "i18next": "23.7.11",
    "lodash": "^4.18.1",
    "prettier": "^2.1.1",
    "querystring": "^0.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "7.34.2",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.30.3",
    "sass": "^1.77.2",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.35.0",
    "vite": "^8.0.3",
    "vite-plugin-svgr": "^4.2.0"
  },
  "scripts": {
    "app:version": "echo \"$npm_package_version\"",
    "start": "yarn clear-babel-cache && yarn update-runtime-env && vite",
    "build": "yarn ts-check:build && vite build",
    "preview": "yarn clear-babel-cache && yarn update-runtime-env && vite preview",
    "test": "NODE_ENV=test yarn update-runtime-env && vitest --config vitest.config.ts",
    "test:coverage": "CI=true yarn test --coverage",
    "ts-check": "tsc --skipLibCheck --noEmit --project tsconfig.build.json",
    "ts-check:build": "tsc --skipLibCheck --noEmit --project tsconfig.build.json",
    "ts-check:test": "tsc --skipLibCheck --noEmit --project tsconfig.test.json",
    "lint:css": "stylelint 'src/**/*.scss'",
    "lint": "yarn lint:css && yarn ts-check:build && eslint src",
    "test:e2e:install": "yarn playwright install",
    "test:e2e:ci": "yarn playwright test",
    "test:e2e:start": "yarn playwright test",
    "update-runtime-env": "esrun --tsconfig=./scripts/tsconfig.json scripts/update-runtime-env.ts",
    "clear-babel-cache": "rm -rf ./node_modules/.cache/@babel",
    "open-local": "./scripts/open_local.sh",
    "postinstall": "if test \"$NODE_ENV\" != \"production\" ; then husky install ; fi && yarn update-runtime-env"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.3",
    "@commitlint/config-conventional": "^18.4.3",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@vitest/coverage-istanbul": "^4.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^8.0.3",
    "jsdom": "^26.1.0",
    "react-test-renderer": "^18.2.0",
    "shadow-dom-testing-library": "^1.11.3",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.0.1",
    "vitest": "^4.1.2"
  },
  "resolutions": {
    "vite": "^8.0.3",
    "picomatch": "4.0.4",
    "**/@typescript-eslint/typescript-estree/minimatch": "9.0.7"
  }
}
